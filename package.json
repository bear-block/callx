{
  "name": "@bear-block/callx",
  "version": "1.1.1",
  "description": "React Native library for handling incoming calls with native UI integration",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "scripts": {
    "example": "yarn workspace callx-example",
    "build": "bob build",
    "build:plugin": "rimraf plugin/build && tsc --build plugin",
    "prepare": "bob build && yarn run build:plugin",
    "release": "release-it --only-version",
    "typecheck": "tsc",
    "lint": "eslint \"**/*.{js,ts,tsx}\"",
    "lint:fix": "eslint \"**/*.{js,ts,tsx}\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "clean": "del-cli android/build example/android/build example/android/app/build example/ios/build lib plugin/build"
  },
  "keywords": [
    "react-native",
    "incoming-call",
    "callkit",
    "pushkit",
    "fcm",
    "voip",
    "call-ui",
    "native-ui",
    "expo",
    "expo-plugin"
  ],
  "author": "Bear Block",
  "license": "MIT",
  "peerDependencies": {
    "react": "*",
    "react-native": "*"
  },
  "devDependencies": {
    "@expo/config-plugins": "^7.0.0",
    "@release-it/conventional-changelog": "^9.0.2",
    "@types/react": "^18.0.0",
    "@types/react-native": "^0.72.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "del-cli": "^5.1.0",
    "eslint": "^8.0.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "eslint-plugin-react": "^7.0.0",
    "eslint-plugin-react-hooks": "^4.0.0",
    "eslint-plugin-react-native": "^4.0.0",
    "jest": "^29.0.0",
    "prettier": "^3.0.0",
    "react": "19.0.0",
    "react-native": "0.79.2",
    "react-native-builder-bob": "^0.40.12",
    "release-it": "^17.10.0",
    "rimraf": "^5.0.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "react-native": "*"
  },
  "files": [
    "lib/**/*",
    "android/**/*",
    "ios/**/*",
    "plugin/**/*",
    "src/**/*",
    "*.podspec",
    "*.gradle",
    "README.md",
    "LICENSE"
  ],
  "react-native": {
    "android": {
      "packageImportPath": "import com.callx.CallxPackage;",
      "packageInstance": "new CallxPackage()"
    },
    "ios": {
      "project": "ios/Callx.xcodeproj"
    }
  },
  "expo": {
    "name": "callx",
    "platforms": [
      "ios",
      "android"
    ]
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      [
        "module",
        {
          "esm": true
        }
      ],
      "typescript"
    ]
  },
  "release-it": {
    "git": {
      "commitMessage": "chore: release ${version}",
      "tagName": "v${version}"
    },
    "npm": {
      "publish": true
    },
    "github": {
      "release": true
    },
    "plugins": {
      "@release-it/conventional-changelog": {
        "preset": {
          "name": "angular"
        }
      }
    }
  }
}
