{
  "name": "@bear-block/callx",
  "version": "1.1.1",
  "description": "React Native library for handling incoming calls with native UI integration",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "scripts": {
    "build": "tsc",
    "build:plugin": "cd plugin && tsc",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.jsx --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "clean": "rm -rf lib plugin/build",
    "prepublishOnly": "yarn clean && yarn build && yarn build:plugin"
  },
  "keywords": [
    "react-native",
    "incoming-call",
    "callkit",
    "pushkit",
    "fcm",
    "voip",
    "call-ui",
    "native-ui",
    "expo",
    "expo-plugin"
  ],
  "author": "Bear Block",
  "license": "MIT",
  "peerDependencies": {
    "react": "*",
    "react-native": "*"
  },
  "devDependencies": {
    "@types/react": "^18.0.0",
    "@types/react-native": "^0.72.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "eslint-plugin-react": "^7.0.0",
    "eslint-plugin-react-hooks": "^4.0.0",
    "eslint-plugin-react-native": "^4.0.0",
    "jest": "^29.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "react-native": "*"
  },
  "files": [
    "lib/**/*",
    "android/**/*",
    "ios/**/*",
    "plugin/**/*",
    "src/**/*",
    "*.podspec",
    "*.gradle",
    "README.md",
    "LICENSE"
  ],
  "react-native": {
    "android": {
      "packageImportPath": "import com.callx.CallxPackage;",
      "packageInstance": "new CallxPackage()"
    },
    "ios": {
      "project": "ios/Callx.xcodeproj"
    }
  },
  "expo": {
    "name": "callx",
    "platforms": ["ios", "android"]
  }
}
